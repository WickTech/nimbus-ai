# --- Database (SQLite for local dev; swap to Postgres URL in prod) ---
DATABASE_URL="file:./prisma/dev.db"

# --- Auth (NextAuth v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"

# --- LLM provider ---
OPENAI_API_KEY="sk-..."
# Optional: point at any OpenAI-compatible endpoint (Ollama, Together, Groq, etc.)
# OPENAI_BASE_URL="http://localhost:11434/v1"
OPENAI_MODEL="gpt-4o-mini"

# --- Billing ---
# Credits granted to a new account on signup.
SIGNUP_FREE_CREDITS="100"
